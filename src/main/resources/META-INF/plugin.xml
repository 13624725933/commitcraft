<idea-plugin>
    <id>com.local.gitcommitai</id>
    <name>Git Commit AI</name>
    <vendor>Local</vendor>
    <version>0.1.3</version>
    <idea-version since-build="242"/>

    <description><![CDATA[
        Generate concise Git commit messages from the current diff using an OpenAI-compatible LLM endpoint.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.local.gitcommitai.config.GitCommitAiSettings"/>
        <applicationConfigurable
                parentId="tools"
                instance="com.local.gitcommitai.config.GitCommitAiConfigurable"
                id="com.local.gitcommitai.settings"
                displayName="Git Commit AI"/>
        <notificationGroup id="Git Commit AI" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action
                id="com.local.gitcommitai.GenerateCommitMessage"
                class="com.local.gitcommitai.action.GenerateCommitMessageAction"
                text="Generate AI Commit Message"
                description="Generate a Git commit message from the current diff"
                icon="AllIcons.Actions.IntentionBulb">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="ChangesView.CommitToolbar" anchor="after" relative-to-action="Vcs.MessageActionGroup"/>
            <add-to-group group-id="ChangesViewPopupMenu" anchor="after" relative-to-action="CheckinFiles"/>
        </action>
    </actions>
</idea-plugin>
