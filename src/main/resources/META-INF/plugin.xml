<idea-plugin>
    <id>com.local.commitcraft</id>
    <name>CommitCraft</name>
    <vendor>CommitCraft</vendor>
    <version>0.2.3</version>
    <idea-version since-build="242"/>

    <description><![CDATA[
        CommitCraft generates concise Git commit messages from the current diff using an OpenAI-compatible LLM endpoint.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.local.commitcraft.config.CommitCraftSettings"/>
        <applicationConfigurable
                parentId="tools"
                instance="com.local.commitcraft.config.CommitCraftConfigurable"
                id="com.local.commitcraft.settings"
                displayName="CommitCraft"/>
        <notificationGroup id="CommitCraft" displayType="BALLOON"/>
    </extensions>

    <actions>
        <action
                id="com.local.commitcraft.GenerateCommitMessage"
                class="com.local.commitcraft.action.GenerateCommitMessageAction"
                text="Generate Commit Message"
                description="Generate a Git commit message from the current diff"
                icon="/icons/commitcraft.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="ChangesView.CommitToolbar" anchor="after" relative-to-action="Vcs.MessageActionGroup"/>
            <add-to-group group-id="ChangesViewPopupMenu" anchor="after" relative-to-action="CheckinFiles"/>
        </action>
    </actions>
</idea-plugin>
